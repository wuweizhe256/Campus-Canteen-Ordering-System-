        </mxCell>

        <mxCell id="lane_ui" value="UI 主线程：PyQt6 Widgets" style="swimlane;html=1;startSize=30;horizontal=0;fillColor=#F8FAFC;strokeColor=#94A3B8;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="430" height="1010" as="geometry"/>
