        </mxCell>

        <mxCell id="controller" value="MainController&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;接收 UI 信号&lt;br&gt;创建 QThread 和 SimulationWorker&lt;br&gt;连接跨线程信号槽&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#DBEAFE;strokeColor=#0284C7;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="545" y="170" width="300" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="thread" value="QThread 生命周期&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;worker.moveToThread(thread)&lt;br&gt;thread.started -&gt; worker.run&lt;br&gt;finished/error -&gt; cleanup&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#E0F2FE;strokeColor=#0284C7;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="545" y="350" width="300" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="direct_controls" value="DirectConnection 控制信号&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;stopWorker -&gt; stop()&lt;br&gt;pauseWorker(bool) -&gt; set_paused(bool)&lt;br&gt;updateTimeScale(float) -&gt; set_time_scale(float)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="545" y="535" width="300" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="queued_returns" value="QueuedConnection 返回 UI&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;frameReady(dict)&lt;br&gt;statusChanged(str)&lt;br&gt;finished(RunSummary)&lt;br&gt;errorOccurred(Exception)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="545" y="735" width="300" height="135" as="geometry"/>
        </mxCell>

        <mxCell id="worker" value="SimulationWorker(QObject)&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;运行在 QThread&lt;br&gt;持有：SimulationConfig、RNG、stalls、tables、students&lt;br&gt;状态：game_time、time_scale、paused、stop_requested&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#CCFBF1;strokeColor=#0D9488;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="975" y="135" width="395" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="init_layout" value="初始化布局与实体&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;画布：1280x800&lt;br&gt;door=(52,72)、exit=(1228,740)&lt;br&gt;10 个窗口、24 张四人桌&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="975" y="315" width="395" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="loop" value="仿真循环 run()&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;while not stop and game_time &lt; duration&lt;br&gt;暂停时只 sleep，不推进时间&lt;br&gt;game_delta = real_delta * time_scale&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="975" y="485" width="395" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="rules" value="业务规则推进&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;每 24 游戏秒按三角峰值生成学生&lt;br&gt;学生偏好与窗口荤素向量做曼哈顿距离匹配&lt;br&gt;排队、做饭倒计时、入座、吃饭、从出口离开&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFEDD5;strokeColor=#F97316;fontSize=13;fontStyle=1;" vertex="1" parent="1">
