        <mxCell id="lane_controller" value="控制层：MainController / 线程桥接" style="swimlane;html=1;startSize=30;horizontal=0;fillColor=#F0F9FF;strokeColor=#38BDF8;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="90" width="390" height="1010" as="geometry"/>
