        <mxCell id="lane_worker" value="仿真工作线程：SimulationWorker in QThread" style="swimlane;html=1;startSize=30;horizontal=0;fillColor=#F0FDFA;strokeColor=#2DD4BF;fontStyle=1;" vertex="1" parent="1">
