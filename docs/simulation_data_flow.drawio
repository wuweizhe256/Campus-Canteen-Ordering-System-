        </mxCell>

        <mxCell id="main_py" value="main.py&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;QApplication&lt;br&gt;MainWindow&lt;br&gt;MainController&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=13;fontStyle=1;" vertex="1" parent="1">
