        </mxCell>
        <mxCell id="config_dialog" value="ConfigDialog&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;用户配置：sim_minutes 30-60&lt;br&gt;stall_count、table_count、seed&lt;br&gt;输出：SimulationConfig&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="95" y="430" width="310" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="canvas_widget" value="CanvasWidget&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;绘制 1280x800 逻辑画布&lt;br&gt;等比缩放适配 2560x1600&lt;br&gt;大门、出口、窗口、厨师猪、倒计时条、桌子、学生猪表情&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FCE7F3;strokeColor=#DB2777;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="95" y="600" width="310" height="145" as="geometry"/>
        </mxCell>
        <mxCell id="status_ui" value="UI 状态更新&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;set_status(str)&lt;br&gt;simulation_finished(RunSummary)&lt;br&gt;show_error(Exception)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#F1F5F9;strokeColor=#64748B;fontSize=13;fontStyle=1;" vertex="1" parent="1">
