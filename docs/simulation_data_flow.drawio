        </mxCell>
        <mxCell id="main_window" value="MainWindow&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;按钮：开始 / 暂停 / 停止&lt;br&gt;滑条：time_scale 1x-24x&lt;br&gt;信号：startRequested、pauseChanged、stopRequested、timeScaleChanged&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#E0F2FE;strokeColor=#0284C7;fontSize=13;fontStyle=1;" vertex="1" parent="1">
